# Copy to .env for local dev (optional — without DATABASE_URL it uses a local PGlite file).
# Admin passcode for the /admin area. CHANGE THIS.
ADMIN_CODE=changeme

# Postgres connection string. Leave unset locally to use in-process PGlite (./.data).
# In production (Render), set this to your Neon connection string.
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
